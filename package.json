{
  "private": true,
  "name": "debugmate-cli",
  "version": "0.2.0",
  "description": "CLI debugging tool (refactored)",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf node_modules package-lock.json",
    "build": "rimraf lib && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "debug": "ts-node src/index.ts",
    "debug:pre": "ts-node src/index.ts --pre",
    "start": "ts-node src/index.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
